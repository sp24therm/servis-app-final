{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "A customer who owns boilers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "phone"]
    },
    "Boiler": {
      "title": "Boiler",
      "description": "A boiler unit belonging to a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "installDate": { "type": "string" },
        "notes": { "type": "string" },
        "lastServiceDate": { "type": "string" },
        "nextServiceDate": { "type": "string" }
      },
      "required": ["id", "customerId", "name", "address", "brand", "model", "serialNumber", "installDate"]
    },
    "ServiceRecord": {
      "title": "ServiceRecord",
      "description": "A record of a service performed on a boiler.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "boilerId": { "type": "string" },
        "date": { "type": "string" },
        "taskPerformed": { "type": "string" },
        "co2Value": { "type": "number" },
        "pressureValue": { "type": "number" },
        "status": { "type": "string" },
        "technicianNotes": { "type": "string" },
        "signature": { "type": "string" },
        "photo": { "type": "string" },
        "co2Max": { "type": "number" },
        "co2Min": { "type": "number" },
        "o2Max": { "type": "number" },
        "o2Min": { "type": "number" },
        "efficiency": { "type": "number" },
        "gasPressure": { "type": "number" },
        "expansionTankPressureCH": { "type": "number" },
        "hasDHWExpansionTank": { "type": "boolean" },
        "expansionTankPressureDHW": { "type": "number" },
        "conductivity": { "type": "number" },
        "phCH": { "type": "number" },
        "hardnessCH": { "type": "number" },
        "burnerCheck": { "type": "boolean" },
        "combustionChamberCleaning": { "type": "boolean" },
        "electrodesCheck": { "type": "boolean" },
        "exchangerCheck": { "type": "boolean" },
        "fanCheck": { "type": "boolean" },
        "filtersCleaning": { "type": "boolean" },
        "siphonCleaning": { "type": "boolean" },
        "gasCircuitTightness": { "type": "boolean" },
        "flueGasOutletTightness": { "type": "boolean" },
        "pumpCheck": { "type": "boolean" },
        "threeWayValveCheck": { "type": "boolean" },
        "airSupplyVentilation": { "type": "boolean" },
        "emergencyStatesCheck": { "type": "boolean" },
        "bondingProtection": { "type": "boolean" }
      },
      "required": ["id", "boilerId", "date", "taskPerformed", "status"]
    }
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers."
    },
    "/boilers/{boilerId}": {
      "schema": "Boiler",
      "description": "Collection of boilers."
    },
    "/services/{serviceId}": {
      "schema": "ServiceRecord",
      "description": "Collection of service records."
    }
  }
}
