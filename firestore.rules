rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - isWinter: boolean (required) - Whether the app is in winter mode.
    //
    // Collection: errorCodes
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required) - The error code (e.g., '108').
    //   - brand: string (required) - The boiler brand (e.g., 'ATAG').
    //   - category: string (required) - 'Nebezpečné', 'Reštart', 'Urob si sám'.
    //   - description: string (required) - Brief description.
    //   - instruction: string (required) - UX instructions.
    //
    // Collection: bookings
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - address: string (optional)
    //   - boilerBrand: string (optional)
    //   - notes: string (optional)
    //   - preferredDate: string (required, YYYY-MM-DD)
    //   - preferredTime: string (required, HH:MM)
    //   - serviceType: string (required, 'Oprava/Servis')
    //   - status: string (required, 'pending')
    //   - createdAt: string (required, ISO)
    //
    // Collection: slots
    // Document ID: auto-generated
    // Fields:
    //   - date: string (required)
    //   - time: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "scepanpeter@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidGlobalSettings(data) {
      return data.keys().hasAll(['isWinter']) &&
             data.isWinter is bool;
    }

    function isValidErrorCode(data) {
      return data.keys().hasAll(['code', 'brand', 'category', 'description', 'instruction']) &&
             data.code is string && data.code.size() > 0 && data.code.size() < 20 &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 50 &&
             data.category in ['Nebezpečné', 'Reštart', 'Urob si sám'] &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.instruction is string && data.instruction.size() > 0 && data.instruction.size() < 2000;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'phone', 'status', 'createdAt', 'preferredDate', 'preferredTime', 'serviceType']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.status == 'pending' &&
             data.createdAt is string &&
             data.preferredDate is string && data.preferredDate.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.preferredTime is string && data.preferredTime.matches("^\\d{2}:\\d{2}$") &&
             data.serviceType == 'Oprava/Servis';
    }

    function isValidSlot(data) {
      return data.keys().hasAll(['date', 'time']) &&
             data.date is string && data.time is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Global Settings: Publicly readable, only admin can write
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidGlobalSettings(request.resource.data);
    }

    // Error Codes: Publicly readable, only admin can write
    match /errorCodes/{errorCodeId} {
      allow read: if true;
      allow write: if isAdmin() && isValidErrorCode(request.resource.data);
    }

    // Bookings: Publicly createable, only admin can read/write
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    // Slots: Publicly readable, only admin can write (or created via batch with booking)
    match /slots/{slotId} {
      allow read: if true;
      allow create: if isValidSlot(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
