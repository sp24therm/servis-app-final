{
  "entities": {
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Global application settings including seasonal configuration.",
      "type": "object",
      "properties": {
        "isWinter": {
          "type": "boolean",
          "description": "Whether the application is in winter mode."
        }
      },
      "required": ["isWinter"]
    },
    "ErrorCode": {
      "title": "Error Code",
      "description": "Diagnostic error code information.",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "The error code (e.g., '108')."
        },
        "brand": {
          "type": "string",
          "description": "The boiler brand (e.g., 'ATAG')."
        },
        "category": {
          "type": "string",
          "enum": ["Nebezpečné", "Reštart", "Urob si sám"],
          "description": "The severity category of the error."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the error."
        },
        "instruction": {
          "type": "string",
          "description": "Detailed UX instructions for the user."
        }
      },
      "required": ["code", "brand", "category", "description", "instruction"]
    }
    "Booking": {
      "title": "Booking",
      "description": "A service request from a customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "boilerBrand": { "type": "string" },
        "notes": { "type": "string" },
        "preferredDate": { "type": "string", "format": "date" },
        "preferredTime": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "status", "createdAt", "preferredDate", "preferredTime", "serviceType"]
    },
    "PublicSlot": {
      "title": "Public Slot",
      "description": "A record of a taken time slot for availability checking.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["date", "time"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "GlobalSettings",
      "description": "Global configuration document."
    },
    "/errorCodes/{errorCodeId}": {
      "schema": "ErrorCode",
      "description": "Collection of diagnostic error codes."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Customer service bookings (Admin only)."
    },
    "/slots/{slotId}": {
      "schema": "PublicSlot",
      "description": "Publicly visible busy slots."
    }
  }
}
